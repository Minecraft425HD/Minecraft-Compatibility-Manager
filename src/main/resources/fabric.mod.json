{
  "schemaVersion": 1,
  "id": "compatmanager",
  "version": "${version}",
  "name": "Minecraft Compatibility Manager",
  "description": "Automatically detects mod compatibility issues and provides solution suggestions.",
  "authors": ["CompatManager Team"],
  "contact": {
    "sources": "https://github.com/minecraft425hd/minecraft-compatibility-manager"
  },
  "license": "MIT",
  "icon": "assets/compatmanager/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["dev.compatmanager.CompatManagerMod"],
    "client": ["dev.compatmanager.CompatManagerClient"]
  },
  "mixins": ["compatmanager.mixins.json"],
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "~1.20.1",
    "java": ">=17"
  }
}
